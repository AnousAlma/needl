# Copy to .env in this folder (frontend/.env) and fill from Firebase Console
# Project settings → Your apps → Web app config

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Optional: Node driver API (repo root: npm run api). iOS simulator: http://127.0.0.1:3001
# Android emulator: http://10.0.2.2:3001 — physical device: your machine LAN IP.
EXPO_PUBLIC_DRIVER_API_URL=

# Donations use the same driver API (Stripe Checkout is created server-side).
