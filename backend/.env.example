PORT=3001

# --- Firebase Admin (pick ONE approach) ---

# Option A — env vars (good for hosting: Vercel, Railway, Fly, etc.)
# Copy from the downloaded service account JSON: project_id, client_email, private_key.
# Put the private key in ONE line; replace real newlines with the two characters \ and n.
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# Option B — JSON file on disk (local dev)
# FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccount.json

# Optional: comma-separated origins for CORS (default allows any origin for local dev)
# CORS_ORIGINS=http://localhost:8081
