PORT=3001

FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# --- CORS (required for production) ---
# Comma-separated list of allowed origins. Must be set in production; omitting it blocks all cross-origin requests.
# Example: CORS_ORIGINS=https://yourapp.com,https://api.yourapp.com
CORS_ORIGINS=

# --- Stripe (optional one-time donations via Settings → Donate) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...   # stripe listen --forward-to localhost:3001/v1/stripe/webhook
STRIPE_DONATE_CURRENCY=cad
STRIPE_DONATE_PRODUCT_NAME=Support Needl
# Optional: comma-separated URL prefixes; if unset, https/exp/custom schemes are allowed (http is not).
# DONATE_REDIRECT_ALLOWLIST=https://yourapp.com,needl://
